# --- Core ---
APP_ENV=development
APP_NAME=talk-confident
LOG_LEVEL=INFO

# --- Database ---
# Use a real Postgres URL in production. Example for docker-compose below.
DATABASE_URL=postgresql+asyncpg://talkconfident:talkconfident@localhost:5432/talkconfident

# --- Auth ---
# Sign your own JWTs with this secret. Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=43200  # 30 days

# Google OAuth Android client ID from Google Cloud Console > Credentials.
# Client secret is NOT needed for the Android Sign-In flow.
GOOGLE_OAUTH_CLIENT_ID=your-android-oauth-client-id.apps.googleusercontent.com
# Optional: a second audience (e.g., a web client) if you also test from a browser.
GOOGLE_OAUTH_ADDITIONAL_AUDIENCES=

# --- Gemini ---
GEMINI_API_KEY=your-gemini-api-key
# Gemini 3.1 Flash-Lite: cheapest Gemini 3 tier with native audio + caching.
# https://ai.google.dev/gemini-api/docs/models/gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite
# Reasoning depth knob. Allowed: minimal | low | medium | high. Default "high".
# https://ai.google.dev/gemini-api/docs/gemini-3
GEMINI_THINKING_LEVEL=high
GEMINI_CACHE_TTL_SECONDS=3600

# --- Context management ---
CONTEXT_TOKEN_THRESHOLD=80000

# --- Uploads ---
MAX_AUDIO_BYTES=52428800  # 50 MB
INLINE_AUDIO_THRESHOLD_BYTES=20971520  # 20 MB

# --- Self-poll keepalive ---
# Render's free tier spins instances down after ~15 min idle. The app
# self-pings to stay warm. Leave SELF_PING_URL blank to fall back to
# RENDER_EXTERNAL_URL (Render injects this automatically); set it manually
# if you host elsewhere. Set the interval to 0 only if you want to disable
# (the loop refuses anything below 30s, so use a far-future value or unset
# SELF_PING_URL and RENDER_EXTERNAL_URL to fully disable).
SELF_PING_URL=
SELF_PING_INTERVAL_SECONDS=600  # 10 minutes
SELF_PING_PATH=/healthz

# --- CORS ---
# Comma-separated list of allowed origins for the Android dev tools (Expo, web preview, etc.).
CORS_ORIGINS=http://localhost:8081,http://localhost:5173,http://10.0.2.2:8000
