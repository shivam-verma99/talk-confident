# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt
.Python

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# ---------------------------------------------------------------------------
# Secrets — NEVER commit. .env.example is the only allowed checked-in env file.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/
local.properties

# ---------------------------------------------------------------------------
# Test / lint / type-check caches
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/
.hypothesis/

# ---------------------------------------------------------------------------
# Build artefacts
# ---------------------------------------------------------------------------
dist/
build/
*.manifest
*.spec

# ---------------------------------------------------------------------------
# IDE / editor / OS noise
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# Local databases / Alembic stragglers
# ---------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# ---------------------------------------------------------------------------
# Audio — server is device-only; if a dev ever creates a clip, never commit it.
# ---------------------------------------------------------------------------
*.wav
*.mp3
*.m4a
*.aac
*.ogg
*.flac

# ---------------------------------------------------------------------------
# Jupyter / notebooks (in case of ad-hoc exploration)
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

